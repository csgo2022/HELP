.page-container {
  padding: 0 48rpx;
  min-height: 100vh;
  padding-bottom: 100rpx;
}

.review-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 64rpx;
}

.review-avatar-wrap {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 6rpx solid #fff;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.1);
  margin-bottom: 32rpx;
}

.review-avatar {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.review-avatar-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  background: #f1f1f1;
}

.review-heading {
  font-size: 44rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 12rpx;
}

.review-subheading {
  font-size: 28rpx;
  color: #a1a1aa;
  font-weight: 700;
  display: block;
  margin-bottom: 48rpx;
}

/* Stars */
.star-rating {
  display: flex;
  gap: 12rpx;
  margin-bottom: 64rpx;
}

.star-item {
  font-size: 72rpx;
  padding: 16rpx;
  transition: all 0.2s;
  opacity: 0.3;
}

.star-item.active {
  opacity: 1;
}

.star-item:active {
  transform: scale(1.1);
}

/* Form */
.review-form {
  width: 100%;
  margin-bottom: 48rpx;
}

.review-form-label {
  font-size: 36rpx;
  font-weight: 700;
  display: block;
  padding: 0 8rpx;
  margin-bottom: 24rpx;
}

.review-textarea {
  width: 100%;
  height: 320rpx;
  background: #fff;
  border-radius: 48rpx;
  border: 3rpx solid #f1f1f1;
  padding: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  box-sizing: border-box;
  line-height: 1.5;
}

.review-textarea:focus {
  border-color: var(--color-primary-container);
}

.submit-review-btn {
  width: 100%;
  height: 140rpx;
  background: var(--color-primary-container);
  color: #fff;
  border-radius: 48rpx;
  font-size: 36rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  border: none;
  box-shadow: 0 12rpx 32rpx -4rpx rgba(148,107,82,0.2);
  line-height: 140rpx;
}

.submit-review-btn:active {
  transform: scale(0.96);
}
