.page-container {
  padding: 0 48rpx;
  min-height: 100vh;
  padding-bottom: 100rpx;
}

.bind-tip {
  background: rgba(38, 109, 0, 0.12);
  padding: 48rpx;
  border-radius: 48rpx;
  border-left: 10rpx solid var(--color-secondary);
  color: var(--color-on-surface);
  font-weight: 700;
  font-size: 28rpx;
  line-height: 1.5;
  margin: 48rpx 0;
}

.form-area {
  margin-bottom: 80rpx;
}

.input-group {
  margin-bottom: 48rpx;
}

.input-label {
  font-size: 36rpx;
  font-weight: 700;
  display: block;
  padding: 0 8rpx;
  margin-bottom: 20rpx;
}

.input-field {
  width: 100%;
  height: 112rpx;
  background: #fff;
  border: 3rpx solid #f1f1f1;
  border-radius: 24rpx;
  padding: 0 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  box-sizing: border-box;
}

.input-field:focus {
  border-color: var(--color-primary-container);
}
