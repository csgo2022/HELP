<view class="register-page">
  <button class="back-btn-top" bindtap="goBack">◀</button>

  <view class="register-hero">
    <text class="register-title">加入社区</text>
    <text class="register-subtitle">开启您的智慧康养之旅</text>
  </view>

  <view class="form-area">
    <view class="form-group">
      <text class="form-label">手机号</text>
      <view class="input-wrapper">
        <text class="input-icon">📞</text>
        <input class="form-input" type="text" placeholder="请输入手机号" value="{{phoneNumber}}" bindinput="onPhoneInput" />
      </view>
    </view>

    <view class="form-group">
      <text class="form-label">验证码</text>
      <view class="code-row">
        <view class="input-wrapper flex-1">
          <text class="input-icon">✅</text>
          <input class="form-input" type="number" placeholder="请输入验证码" value="{{code}}" bindinput="onCodeInput" />
        </view>
        <button class="code-btn" bindtap="getCode">获取验证码</button>
      </view>
    </view>

    <view class="form-group">
      <text class="form-label">设置密码</text>
      <view class="input-wrapper">
        <text class="input-icon">🔒</text>
        <input class="form-input" type="password" placeholder="请设置 6-20 位密码" value="{{password}}" bindinput="onPasswordInput" />
      </view>
    </view>

    <view class="form-group">
      <text class="form-label">确认密码</text>
      <view class="input-wrapper">
        <text class="input-icon">✅</text>
        <input class="form-input" type="password" placeholder="请再次输入密码" value="{{confirmPassword}}" bindinput="onConfirmPasswordInput" />
      </view>
    </view>
  </view>

  <button class="register-btn" bindtap="handleRegister">
    <text>注册并登录</text>
    <text>▶</text>
  </button>
</view>
