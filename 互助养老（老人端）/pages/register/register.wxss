.register-page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding: 80rpx 64rpx 60rpx;
  background: #fff;
  box-sizing: border-box;
  position: relative;
}

.back-btn-top {
  position: absolute;
  top: 40rpx;
  left: 40rpx;
  z-index: 10;
  width: 72rpx;
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #a1a1aa;
  border: none;
  line-height: 72rpx;
}

.back-btn-top:active {
  transform: scale(0.96);
}

.register-hero {
  margin-bottom: 80rpx;
  padding-top: 60rpx;
}

.register-title {
  font-size: 56rpx;
  font-weight: 800;
  color: var(--color-primary-container);
  display: block;
  margin-bottom: 16rpx;
}

.register-subtitle {
  font-size: 32rpx;
  color: #a1a1aa;
  font-weight: 700;
  display: block;
}

.form-area {
  display: flex;
  flex-direction: column;
  gap: 40rpx;
  flex: 1;
}

.form-group {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.form-label {
  font-size: 32rpx;
  font-weight: 700;
  color: #52525b;
  margin-left: 8rpx;
}

.input-wrapper {
  display: flex;
  align-items: center;
  height: 112rpx;
  background: #f5f5f5;
  border-radius: 24rpx;
  border: 3rpx solid transparent;
  padding: 0 32rpx;
}

.input-wrapper:focus-within {
  border-color: var(--color-primary-container);
}

.input-icon {
  font-size: 32rpx;
  color: #a1a1aa;
  margin-right: 20rpx;
}

.form-input {
  flex: 1;
  height: 100%;
  font-size: 32rpx;
  font-weight: 700;
  background: transparent;
  border: none;
  outline: none;
}

.code-row {
  display: flex;
  gap: 20rpx;
}

.flex-1 {
  flex: 1;
}

.code-btn {
  height: 112rpx;
  padding: 0 48rpx;
  background: #fff1e6;
  color: var(--color-primary-container);
  font-weight: 700;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  border: none;
  white-space: nowrap;
  line-height: 112rpx;
}

.code-btn:active {
  transform: scale(0.96);
}

.register-btn {
  width: 100%;
  height: 112rpx;
  background: var(--color-primary-container);
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  border: none;
  margin-top: 48rpx;
  box-shadow: 0 12rpx 32rpx -4rpx rgba(148, 107, 82, 0.2);
  line-height: 112rpx;
}

.register-btn:active {
  transform: scale(0.96);
}

.agree-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-top: 48rpx;
}

.agree-checkbox {
  width: 36rpx;
  height: 36rpx;
  accent-color: var(--color-secondary);
}

.agree-text {
  font-size: 24rpx;
  color: #a1a1aa;
  font-weight: 700;
}

.agree-link {
  font-size: 24rpx;
  color: var(--color-secondary);
  font-weight: 700;
}
