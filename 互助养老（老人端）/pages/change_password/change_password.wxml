<view class="page-container">
  <view class="page-header">
    <view class="page-header-left">
      <button class="back-btn" bindtap="goBack">◀</button>
      <text class="page-title" style="color: #27272a;">修改密码</text>
    </view>
    <view class="header-spacer"></view>
  </view>

  <view class="form-area">
    <view class="input-group">
      <text class="input-label">当前密码</text>
      <view class="input-with-icon">
        <text class="input-prefix-icon">🔒</text>
        <input class="icon-input" type="password" placeholder="请输入当前密码" value="{{oldPassword}}" bindinput="onOldInput" />
      </view>
    </view>
    <view class="input-group">
      <text class="input-label">新密码</text>
      <view class="input-with-icon">
        <text class="input-prefix-icon">✅</text>
        <input class="icon-input" type="password" placeholder="请设置 6-20 位新密码" value="{{newPassword}}" bindinput="onNewInput" />
      </view>
    </view>
    <view class="input-group">
      <text class="input-label">确认新密码</text>
      <view class="input-with-icon">
        <text class="input-prefix-icon">✅</text>
        <input class="icon-input" type="password" placeholder="请再次确认新密码" value="{{confirmPassword}}" bindinput="onConfirmInput" />
      </view>
    </view>
  </view>

  <button class="primary-btn" bindtap="handleChange">确认修改</button>
</view>
