/* =============================================
   志愿者详情 — 温暖名片设计
   ============================================= */

.page {
  padding: 0 36rpx 80rpx;
  min-height: 100vh;
  background: #f6f0e8;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

/* =============================================
   Header
   ============================================= */
.header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 80rpx 0 8rpx;
}

.header-back {
  width: 64rpx;
  height: 64rpx;
  background: #ffffff;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(100, 60, 30, 0.06);
}

.header-back:active {
  transform: scale(0.92);
}

.header-back-icon {
  width: 32rpx;
  height: 32rpx;
}

.header-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #2c1810;
}

/* =============================================
   Profile Card — 个人名片
   ============================================= */
.profile-card {
  background: #ffffff;
  border-radius: 48rpx;
  overflow: hidden;
  box-shadow:
    0 4rpx 16rpx rgba(100, 60, 30, 0.06),
    0 12rpx 32rpx -8rpx rgba(100, 60, 30, 0.08);
}

.profile-card-top {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 56rpx 40rpx 0;
  position: relative;
}

/* Decorative top bar */
.profile-card-top::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: linear-gradient(145deg, #c7511f 0%, #a83e12 100%);
  border-radius: 0 0 80rpx 80rpx;
}

.profile-avatar-wrap {
  position: relative;
  z-index: 1;
  width: 176rpx;
  height: 176rpx;
  margin-bottom: 20rpx;
}

.profile-avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  object-fit: cover;
  border: 6rpx solid #ffffff;
  box-shadow: 0 8rpx 32rpx rgba(167, 62, 18, 0.2);
}

.profile-avatar-ring {
  position: absolute;
  top: -8rpx;
  left: -8rpx;
  right: -8rpx;
  bottom: -8rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(199, 81, 31, 0.15);
  pointer-events: none;
}

.profile-name {
  font-size: 48rpx;
  font-weight: 900;
  color: #2c1810;
  text-align: center;
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
}

.profile-tags {
  display: flex;
  gap: 16rpx;
  margin-bottom: 40rpx;
}

.profile-tag {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 24rpx;
  border-radius: 100rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.profile-tag-icon {
  width: 28rpx;
  height: 28rpx;
}

.profile-tag-verified {
  background: rgba(58, 125, 76, 0.1);
  color: #3a7d4c;
}

.profile-tag-role {
  background: rgba(199, 81, 31, 0.08);
  color: #c7511f;
}

/* Stats */
.profile-stats {
  display: flex;
  align-items: center;
  border-top: 2rpx solid #f0ebe4;
  padding: 36rpx 16rpx;
}

.profile-stat {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.profile-stat-value {
  font-size: 40rpx;
  font-weight: 800;
  color: #2c1810;
  line-height: 1.2;
}

.profile-stat-label {
  font-size: 22rpx;
  font-weight: 500;
  color: #8a7a6e;
}

.profile-stat-divider {
  width: 2rpx;
  height: 48rpx;
  background: #f0ebe4;
}

/* =============================================
   Section
   ============================================= */
.section {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #2c1810;
  padding: 0 8rpx;
}

.section-title-count {
  font-weight: 500;
  color: #8a7a6e;
}

/* =============================================
   Contact Card — 联系卡片
   ============================================= */
.contact-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: #ffffff;
  border-radius: 40rpx;
  padding: 36rpx;
  box-shadow:
    0 4rpx 16rpx rgba(100, 60, 30, 0.04),
    0 8rpx 24rpx -8rpx rgba(100, 60, 30, 0.06);
}

.contact-card:active {
  transform: scale(0.98);
}

.contact-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  background: rgba(58, 125, 76, 0.1);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.contact-icon {
  width: 36rpx;
  height: 36rpx;
}

.contact-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.contact-label {
  font-size: 24rpx;
  font-weight: 500;
  color: #8a7a6e;
}

.contact-number {
  font-size: 34rpx;
  font-weight: 700;
  color: #2c1810;
  letter-spacing: 1rpx;
}

.contact-call-btn {
  width: 88rpx;
  height: 88rpx;
  background: linear-gradient(145deg, #3a7d4c, #2d6a3e);
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(58, 125, 76, 0.3);
  flex-shrink: 0;
}

.contact-call-btn:active {
  transform: scale(0.9);
}

.contact-call-icon {
  width: 36rpx;
  height: 36rpx;
}

/* =============================================
   Skills — 擅长领域标签
   ============================================= */
.skills-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.skill-tag {
  padding: 20rpx 36rpx;
  background: #ffffff;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #2c1810;
  box-shadow:
    0 4rpx 12rpx rgba(100, 60, 30, 0.04),
    0 6rpx 16rpx -6rpx rgba(100, 60, 30, 0.06);
  border: 2rpx solid rgba(199, 81, 31, 0.06);
}

/* =============================================
   Review Cards — 评价卡片
   ============================================= */
.review-card {
  background: #ffffff;
  border-radius: 36rpx;
  padding: 36rpx;
  box-shadow:
    0 4rpx 16rpx rgba(100, 60, 30, 0.04),
    0 8rpx 24rpx -8rpx rgba(100, 60, 30, 0.06);
  border: 2rpx solid rgba(199, 81, 31, 0.04);
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.review-card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.review-card-user {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.review-card-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  object-fit: cover;
  background: #f0ebe4;
}

.review-card-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #2c1810;
}

.review-card-stars {
  display: flex;
  gap: 4rpx;
}

.review-card-star {
  width: 28rpx;
  height: 28rpx;
}

.review-card-star.star-off {
  opacity: 0.2;
}

.review-card-comment {
  font-size: 28rpx;
  line-height: 1.6;
  color: #52525b;
  font-weight: 500;
  display: block;
}

.review-card-date {
  font-size: 22rpx;
  color: #8a7a6e;
  font-weight: 500;
}

/* =============================================
   Empty Reviews — 空状态
   ============================================= */
.empty-reviews {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 64rpx 0;
}

.empty-reviews-icon {
  width: 96rpx;
  height: 96rpx;
  background: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(100, 60, 30, 0.04);
}

.empty-reviews-icon-img {
  width: 40rpx;
  height: 40rpx;
  opacity: 0.3;
}

.empty-reviews-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #8a7a6e;
  margin-bottom: 8rpx;
}

.empty-reviews-desc {
  font-size: 24rpx;
  font-weight: 500;
  color: #b8a89c;
}
