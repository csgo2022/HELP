.page-container {
  padding: 0 48rpx;
  min-height: 100vh;
  padding-bottom: 100rpx;
}

.announce-list {
  margin-top: 48rpx;
  display: flex;
  flex-direction: column;
  gap: 48rpx;
}

.announce-item {
  background: #fff;
  border-radius: 48rpx;
  padding: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.06);
  border-left: 10rpx solid var(--color-secondary-container);
  transition: all 0.2s;
}

.announce-item:active {
  transform: scale(0.98);
}

.announce-top {
  margin-bottom: 24rpx;
}

.announce-date {
  font-size: 24rpx;
  color: #a1a1aa;
}

.announce-title {
  font-size: 36rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 24rpx;
}

.announce-content {
  font-size: 28rpx;
  color: #71717a;
  line-height: 1.6;
  display: block;
}
