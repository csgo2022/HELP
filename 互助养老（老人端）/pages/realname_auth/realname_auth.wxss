.auth-content {
  padding: 40rpx 0;
  display: flex;
  flex-direction: column;
  flex: 1;
}

.auth-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 64rpx;
  padding-top: 40rpx;
}

.auth-icon-wrap {
  width: 128rpx;
  height: 128rpx;
  background: rgba(255, 140, 66, 0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.auth-title {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--color-on-surface);
  margin-bottom: 16rpx;
  display: block;
}

.auth-subtitle {
  font-size: 28rpx;
  color: #a1a1aa;
  font-weight: 600;
  display: block;
}

.upload-section {
  display: flex;
  gap: 32rpx;
  margin-bottom: 64rpx;
}

.upload-card {
  flex: 1;
  aspect-ratio: 0.7;
}

.upload-placeholder {
  width: 100%;
  height: 100%;
  background: #fff;
  border-radius: 24rpx;
  border: 3rpx dashed #d4d4d8;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  overflow: hidden;
}

.upload-card:active .upload-placeholder {
  border-color: var(--color-primary-container);
  background: #fff8f5;
}

.upload-icon {
  font-size: 64rpx;
}

.upload-label {
  font-size: 28rpx;
  font-weight: 700;
  color: #52525b;
}

.upload-hint {
  font-size: 22rpx;
  color: #a1a1aa;
}

.upload-preview {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.submit-auth-btn {
  width: 100%;
  height: 112rpx;
  background: var(--color-primary-container);
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 700;
  border: none;
  line-height: 112rpx;
  box-shadow: 0 12rpx 32rpx -4rpx rgba(148, 107, 82, 0.2);
  margin-top: auto;
}

.submit-auth-btn:active {
  transform: scale(0.96);
  opacity: 0.9;
}

.submit-auth-btn[disabled] {
  opacity: 0.5;
  box-shadow: none;
}
