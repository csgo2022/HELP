.page-container {
  padding: 0 48rpx;
  min-height: 100vh;
  padding-bottom: 200rpx;
}

/* Header */
.home-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 100rpx 0 24rpx;
  position: sticky;
  top: 0;
  background: rgba(255, 248, 245, 0.8);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  z-index: 10;
}

.avatar-border {
  border: 3rpx solid var(--color-primary-container);
  border-radius: 50%;
  padding: 3rpx;
  overflow: hidden;
  width: 80rpx;
  height: 80rpx;
}

.home-avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  object-fit: cover;
}

.home-title {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--color-primary-container);
  letter-spacing: -1rpx;
}

.notif-btn {
  width: 72rpx;
  height: 72rpx;
  border: none;
  background: none;
  font-size: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  line-height: 1;
  color: var(--color-primary-container);
}

.notif-btn:active {
  transform: scale(0.95);
}

/* Greeting */
.greeting-section {
  padding-top: 48rpx;
  margin-bottom: 64rpx;
}

.greeting-text {
  font-size: 56rpx;
  font-weight: 800;
  color: var(--color-on-surface);
  display: block;
  margin-bottom: 16rpx;
}

.greeting-sub {
  font-size: 32rpx;
  color: var(--color-outline);
  display: block;
}

/* Action Grid */
.action-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 32rpx;
  margin-bottom: 64rpx;
}

.action-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 64rpx 48rpx;
  border-radius: 64rpx;
  border: 6rpx solid #fff;
  transition: all 0.2s;
}

.action-card:active {
  transform: scale(0.96);
}

.primary-action {
  background: var(--color-primary-container);
  box-shadow: 0 12rpx 32rpx -4rpx rgba(148, 107, 82, 0.2);
}

.secondary-action {
  background: var(--color-secondary-container);
  box-shadow: 0 12rpx 32rpx -4rpx rgba(148, 107, 82, 0.15);
}

.action-icon-wrap {
  background: rgba(255, 255, 255, 0.2);
  padding: 32rpx;
  border-radius: 36rpx;
  margin-bottom: 32rpx;
}

.action-icon {
  font-size: 72rpx;
  line-height: 1;
}

.action-label {
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.3;
  text-align: center;
  white-space: pre-line;
}

.primary-action .action-label {
  color: #fff;
}

.secondary-action .action-label {
  color: var(--color-on-surface);
}

/* Announcement */
.announcement-card {
  background: var(--color-surface-container-low);
  border-radius: 48rpx;
  padding: 48rpx;
  border: 3rpx solid var(--color-surface-container-high);
  margin-bottom: 48rpx;
  transition: all 0.2s;
}

.announcement-card:active {
  transform: scale(0.98);
}

.announcement-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.announcement-icon {
  font-size: 40rpx;
  color: var(--color-primary-container);
}

.announcement-title {
  font-size: 36rpx;
  font-weight: 700;
}

.announcement-body {
  background: #fff;
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.04);
}

.announcement-content {
  font-size: 32rpx;
  line-height: 1.6;
  color: #52525b;
  display: block;
}

.announcement-more {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 32rpx;
  color: var(--color-primary-container);
  font-weight: 700;
  font-size: 28rpx;
}

/* Emergency Button */
.emergency-btn {
  position: fixed;
  bottom: 280rpx;
  right: 48rpx;
  width: 140rpx;
  height: 140rpx;
  background: var(--color-error);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 48rpx rgba(186, 26, 26, 0.3);
  border: 6rpx solid #fff;
  z-index: 40;
}

.emergency-icon {
  font-size: 60rpx;
}
