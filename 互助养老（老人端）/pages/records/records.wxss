.page-container {
  padding: 0 48rpx;
  min-height: 100vh;
  padding-bottom: 200rpx;
}

.page-header {
  padding: 30rpx 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: sticky;
  top: 0;
  background: rgba(255, 248, 245, 0.8);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  z-index: 10;
}

.notif-btn {
  width: 72rpx;
  height: 72rpx;
  border: none;
  background: none;
  font-size: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  line-height: 1;
  color: var(--color-primary-container);
}

.notif-btn:active {
  transform: scale(0.95);
}

/* Tab Switch */
.tab-switch {
  display: flex;
  background: var(--color-surface-container-high);
  border-radius: 50rpx;
  padding: 12rpx;
  margin: 48rpx 0 64rpx;
  gap: 16rpx;
}

.tab-switch-item {
  flex: 1;
  padding: 24rpx;
  border-radius: 50rpx;
  font-weight: 700;
  text-align: center;
  font-size: 28rpx;
  color: #71717a;
  transition: all 0.2s;
}

.tab-switch-item.active {
  background: var(--color-primary-container);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(255, 140, 66, 0.3);
}

/* Record Card */
.record-list {
  display: flex;
  flex-direction: column;
  gap: 48rpx;
}

.record-card {
  background: #fff;
  border-radius: 48rpx;
  padding: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.06);
  border-left: 10rpx solid transparent;
  transition: all 0.2s;
}

.record-card:active {
  transform: scale(0.98);
}

.record-card .record-status.in_progress {
  border-left-color: var(--color-primary-container);
}

.record-card .record-status.completed {
  border-left-color: var(--color-secondary);
}

.record-card .record-status.waiting {
  border-left-color: var(--color-primary-container);
}

.record-card-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 32rpx;
}

.record-status {
  padding: 8rpx 32rpx;
  border-radius: 50rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.record-status.in_progress {
  background: var(--color-secondary-container);
  color: var(--color-on-surface);
}

.record-status.completed {
  background: #f4f4f5;
  color: #71717a;
}

.record-status.waiting {
  background: #fff1e6;
  color: var(--color-primary-container);
}

.record-time-label {
  font-size: 24rpx;
  color: #a1a1aa;
}

.record-type {
  font-size: 36rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 16rpx;
}

.record-desc {
  font-size: 28rpx;
  color: #71717a;
  display: block;
  margin-bottom: 32rpx;
  line-height: 1.5;
}

.record-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.record-tag {
  font-size: 24rpx;
  font-weight: 700;
  background: #fafafa;
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  color: #52525b;
}

.review-btn {
  width: 100%;
  margin-top: 48rpx;
  height: 100rpx;
  background: var(--color-secondary-container);
  color: var(--color-on-surface);
  border-radius: 24rpx;
  font-weight: 700;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  border: none;
  line-height: 100rpx;
}

.review-btn:active {
  transform: scale(0.95);
}

.reviewed-badge {
  margin-top: 48rpx;
  height: 100rpx;
  background: #f0fdf4;
  color: #16a34a;
  border-radius: 24rpx;
  font-weight: 700;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #bbf7d0;
}
