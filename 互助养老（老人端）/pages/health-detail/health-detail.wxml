<view class="page-container">
  <!-- Header -->
  <view class="page-header">
    <view class="page-header-left">
      <button class="back-btn" bindtap="goBack">◀</button>
      <text class="page-title">健康报告详情</text>
    </view>
  </view>

  <view class="detail-content" wx:if="{{!loading && analysis}}">
    <!-- Report Image -->
    <view class="report-image-wrap" wx:if="{{record.image}}" bindtap="previewImage" data-url="{{record.image}}">
      <image class="report-image" src="{{record.image}}" mode="aspectFill" />
      <view class="report-image-overlay">
        <text class="report-image-hint">点击查看原图</text>
      </view>
    </view>

    <!-- Record Date -->
    <text class="record-date">📅 {{record.date}}</text>

    <!-- Metrics Grid -->
    <view class="metrics-grid">
      <view class="metric-card" wx:for="{{analysis.metrics}}" wx:key="name">
        <view class="metric-header">
          <image class="icon-svg-sm" src="/images/icons/activity.svg" mode="aspectFit" style="stroke:{{item.status === '偏高' || item.status === '偏低' ? 'var(--color-error)' : 'var(--color-secondary)'}};" />
          <text class="metric-label">{{item.name}}</text>
        </view>
        <view class="metric-value-row">
          <text class="metric-value {{item.status === '偏高' || item.status === '偏低' ? 'warn-value' : 'good-value'}}">{{item.value}}</text>
          <text class="metric-unit" wx:if="{{item.unit}}">{{item.unit}}</text>
        </view>
        <text class="metric-range" wx:if="{{item.range}}">参考: {{item.range}}</text>
        <view class="metric-badge {{item.status === '偏高' || item.status === '偏低' ? 'warn-badge' : (item.status === '正常' ? 'good-badge' : '')}}">
          {{item.status}}
        </view>
      </view>
    </view>

    <!-- AI Advice -->
    <view class="ai-advice-card">
      <view class="ai-advice-header">
        <view class="ai-icon-wrap">
          <image class="icon-svg-lg" src="/images/icons/heart-pulse.svg" mode="aspectFit" style="stroke:#fff;stroke-width:2;" />
        </view>
        <text class="ai-advice-title">AI 智能养护建议</text>
      </view>

      <view class="risk-box" wx:if="{{analysis.riskLevel === 'attention' || analysis.riskLevel === 'warning'}}">
        <text class="risk-title">{{analysis.riskLevel === 'warning' ? '⚠️ 紧急风险提示' : '⚡ 注意事项'}}</text>
        <text class="risk-desc">{{analysis.summary}}</text>
      </view>

      <view class="summary-box" wx:if="{{analysis.riskLevel === 'normal'}}">
        <text class="risk-title">✅ 总体评价</text>
        <text class="risk-desc">{{analysis.summary}}</text>
      </view>

      <view class="advice-list" wx:if="{{analysis.advice && analysis.advice.length > 0}}">
        <text class="advice-title">💡 健康建议</text>
        <view class="advice-item" wx:for="{{analysis.advice}}" wx:key="*this">
          <text class="advice-bullet">•</text>
          <text class="advice-text">{{item}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Loading -->
  <view class="loading-state" wx:if="{{loading}}">
    <text class="loading-text">加载中...</text>
  </view>

  <!-- Not found -->
  <view class="empty-state" wx:if="{{!loading && !analysis}}">
    <image class="empty-icon" src="/images/icons/health.svg" mode="aspectFit" />
    <text class="empty-text">未找到该记录</text>
  </view>
</view>
