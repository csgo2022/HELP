.page-container {
  padding: 0 48rpx;
  min-height: 100vh;
  padding-bottom: 100rpx;
}

.detail-content {
  display: flex;
  flex-direction: column;
  gap: 48rpx;
}

/* Report Image */
.report-image-wrap {
  position: relative;
  border-radius: 36rpx;
  overflow: hidden;
  margin-top: 48rpx;
  box-shadow: 0 12rpx 32rpx -8rpx rgba(148, 107, 82, 0.15);
}

.report-image {
  width: 100%;
  height: 360rpx;
  display: block;
}

.report-image-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.4), transparent);
  padding: 60rpx 32rpx 24rpx;
}

.report-image-hint {
  font-size: 22rpx;
  color: rgba(255,255,255,0.8);
  font-weight: 500;
}

/* Record Date */
.record-date {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-outline);
  display: block;
  text-align: center;
}

/* Metrics Grid */
.metrics-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 28rpx;
  margin-bottom: 0;
}

.metric-card {
  background: #fff;
  padding: 40rpx;
  border-radius: 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 12rpx 32rpx -4rpx rgba(148, 107, 82, 0.15);
  border: 3rpx solid #fafafa;
  width: calc(50% - 14rpx);
  box-sizing: border-box;
  overflow: hidden;
}

.metric-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.metric-label {
  font-size: 24rpx;
  font-weight: 700;
  color: #71717a;
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

.metric-value-row {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.metric-value {
  font-size: 72rpx;
  font-weight: 900;
  line-height: 1;
}

.warn-value {
  color: var(--color-error);
}

.good-value {
  color: var(--color-secondary);
}

.metric-unit {
  font-size: 24rpx;
  color: #a1a1aa;
}

.metric-range {
  font-size: 20rpx;
  color: #a1a1aa;
  text-align: center;
}

.metric-badge {
  padding: 8rpx 24rpx;
  border-radius: 50rpx;
  font-size: 20rpx;
  font-weight: 700;
}

.warn-badge {
  background: var(--color-error-container);
  color: var(--color-error);
}

.good-badge {
  background: var(--color-secondary-container);
  color: var(--color-on-surface);
}

/* AI Advice */
.ai-advice-card {
  background: #fff;
  border-radius: 48rpx;
  padding: 48rpx;
  box-shadow: 0 12rpx 32rpx -4rpx rgba(148, 107, 82, 0.15);
}

.ai-advice-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.ai-icon-wrap {
  padding: 24rpx;
  background: var(--color-primary-container);
  border-radius: 24rpx;
}

.ai-advice-title {
  font-size: 36rpx;
  font-weight: 700;
}

.risk-box {
  background: rgba(186, 26, 26, 0.05);
  border-left: 10rpx solid var(--color-error);
  padding: 32rpx;
  border-radius: 0 24rpx 24rpx 0;
  margin-bottom: 32rpx;
}

.risk-title {
  font-weight: 700;
  color: var(--color-error);
  display: block;
  margin-bottom: 16rpx;
  font-size: 32rpx;
}

.risk-desc {
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--color-on-surface);
}

.summary-box {
  background: rgba(38, 109, 0, 0.05);
  border-left: 10rpx solid var(--color-secondary);
  padding: 32rpx;
  border-radius: 0 24rpx 24rpx 0;
  margin-bottom: 32rpx;
}

.advice-list {
  margin-top: 16rpx;
}

.advice-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-on-surface);
  display: block;
  margin-bottom: 16rpx;
}

.advice-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.advice-bullet {
  color: var(--color-primary-container);
  font-size: 28rpx;
  flex-shrink: 0;
}

.advice-text {
  font-size: 26rpx;
  color: var(--color-on-surface);
  line-height: 1.5;
}

/* Loading & Empty */
.loading-state {
  display: flex;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: var(--color-outline);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 32rpx;
  opacity: 0.4;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-on-surface-variant);
}
