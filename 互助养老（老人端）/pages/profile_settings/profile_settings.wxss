.page-container {
  padding: 0 48rpx;
  min-height: 100vh;
  padding-bottom: 100rpx;
}

/* Avatar Section */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  margin: 64rpx 0;
}

.settings-avatar-wrap {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.settings-avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 6rpx solid #fff;
  object-fit: cover;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.1);
}

.camera-btn {
  position: absolute;
  bottom: 8rpx;
  right: 8rpx;
  background: var(--color-primary-container);
  color: #fff;
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  border: 6rpx solid #fff;
}

.camera-btn:active {
  transform: scale(0.9);
}

.settings-name {
  font-size: 44rpx;
  font-weight: 800;
}

/* Settings Sections */
.settings-section {
  margin-bottom: 48rpx;
}

.settings-section-title {
  font-size: 36rpx;
  font-weight: 700;
  display: block;
  padding: 0 16rpx;
  margin-bottom: 24rpx;
}

.settings-card {
  background: #fff;
  border-radius: 48rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.06);
  border: 1rpx solid #fafafa;
}

.info-item {
  display: flex;
  align-items: center;
  padding: 48rpx;
  border-bottom: 1rpx solid #fafafa;
}

.info-item:last-child {
  border-bottom: none;
}

.info-icon {
  font-size: 40rpx;
  color: #a1a1aa;
  margin-right: 32rpx;
}

.info-label {
  font-size: 32rpx;
  font-weight: 700;
  color: #71717a;
  flex: 1;
}

.info-value {
  font-size: 32rpx;
  font-weight: 700;
}

/* Security Item */
.security-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 48rpx;
}

.security-item:active {
  background: #fafafa;
}

.security-left {
  display: flex;
  align-items: center;
  gap: 28rpx;
}

.security-icon-wrap {
  padding: 24rpx;
  background: var(--color-secondary-container);
  color: var(--color-secondary);
  border-radius: 24rpx;
  font-size: 40rpx;
}

.security-label {
  font-size: 32rpx;
  font-weight: 700;
}

.security-arrow {
  color: #d4d4d8;
  font-size: 28rpx;
}

/* Action Buttons */
.action-buttons {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
  margin-top: 48rpx;
}

.edit-btn {
  width: 100%;
  height: 112rpx;
  background: #fff;
  border: 3rpx solid var(--color-primary-container);
  color: var(--color-primary-container);
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  line-height: 112rpx;
}

.edit-btn:active {
  transform: scale(0.96);
}

.logout-btn {
  width: 100%;
  height: 112rpx;
  background: #fff;
  border: 3rpx solid var(--color-error);
  color: var(--color-error);
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  line-height: 112rpx;
}

.logout-btn:active {
  transform: scale(0.96);
}
