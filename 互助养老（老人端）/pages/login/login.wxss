.login-page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding: 120rpx 64rpx 60rpx;
  background: #fff;
  box-sizing: border-box;
}

.login-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.login-hero {
  margin-bottom: 80rpx;
}

.logo-box {
  width: 120rpx;
  height: 120rpx;
  background: var(--color-primary-container);
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  margin-bottom: 48rpx;
  box-shadow: 0 12rpx 32rpx -4rpx rgba(148, 107, 82, 0.2);
}

.login-title {
  font-size: 64rpx;
  font-weight: 800;
  color: var(--color-primary-container);
  display: block;
  margin-bottom: 16rpx;
}

.login-subtitle {
  font-size: 32rpx;
  color: #a1a1aa;
  font-weight: 700;
  display: block;
}

.login-tabs {
  display: flex;
  gap: 24rpx;
  margin-bottom: 80rpx;
  background: #f5f5f5;
  padding: 12rpx;
  border-radius: 24rpx;
}

.login-tab {
  flex: 1;
  padding: 24rpx;
  font-weight: 700;
  text-align: center;
  border-radius: 16rpx;
  color: #a1a1aa;
  transition: all 0.2s;
}

.login-tab.active {
  background: #fff;
  color: var(--color-primary-container);
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06);
}

.form-area {
  display: flex;
  flex-direction: column;
  gap: 48rpx;
}

.form-group {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.form-label {
  font-size: 32rpx;
  font-weight: 700;
  color: #52525b;
  margin-left: 8rpx;
}

.input-wrapper {
  display: flex;
  align-items: center;
  height: 112rpx;
  background: #f5f5f5;
  border-radius: 24rpx;
  border: 3rpx solid transparent;
  padding: 0 32rpx;
}

.input-wrapper:focus-within {
  border-color: var(--color-primary-container);
}

.input-icon {
  font-size: 32rpx;
  color: #a1a1aa;
  margin-right: 20rpx;
}

.form-input {
  flex: 1;
  height: 100%;
  font-size: 32rpx;
  font-weight: 700;
  background: transparent;
  border: none;
  outline: none;
}

.code-row {
  display: flex;
  gap: 20rpx;
}

.flex-1 {
  flex: 1;
}

.code-btn {
  height: 112rpx;
  padding: 0 48rpx;
  background: #fff1e6;
  color: var(--color-primary-container);
  font-weight: 700;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  border: none;
  white-space: nowrap;
  line-height: 112rpx;
}

.code-btn:active {
  transform: scale(0.96);
}

.login-btn {
  width: 100%;
  height: 112rpx;
  background: var(--color-primary-container);
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  border: none;
  margin-top: 80rpx;
  box-shadow: 0 12rpx 32rpx -4rpx rgba(148, 107, 82, 0.2);
  line-height: 112rpx;
}

.login-btn:active {
  transform: scale(0.96);
}

.register-link {
  text-align: center;
  margin-top: 48rpx;
}

.register-text {
  color: #a1a1aa;
  font-weight: 700;
  font-size: 28rpx;
}

.register-action {
  color: var(--color-secondary);
  font-weight: 700;
  font-size: 28rpx;
  margin-left: 8rpx;
  text-decoration: underline;
  text-underline-offset: 8rpx;
  text-decoration-thickness: 3rpx;
}

.forgot-password-link {
  text-align: center;
  margin-top: 32rpx;
}

.forgot-password-action {
  color: var(--color-primary-container);
  font-weight: 700;
  font-size: 28rpx;
  text-decoration: underline;
  text-underline-offset: 8rpx;
  text-decoration-thickness: 3rpx;
}

.agree-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-top: 64rpx;
}

.agree-checkbox {
  width: 36rpx;
  height: 36rpx;
  accent-color: var(--color-secondary);
}

.agree-text {
  font-size: 24rpx;
  color: #a1a1aa;
  font-weight: 700;
}

.agree-link {
  font-size: 24rpx;
  color: var(--color-secondary);
  font-weight: 700;
}
