.page-container {
  padding: 0 48rpx;
  min-height: 100vh;
  padding-bottom: 100rpx;
}

/* Status Card */
.security-status-card {
  background: #fff;
  padding: 48rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  gap: 48rpx;
  box-shadow: 0 12rpx 32rpx -4rpx rgba(148,107,82,0.15);
  border: 3rpx solid rgba(255,140,66,0.08);
  margin: 48rpx 0;
}

.security-status-icon-wrap {
  width: 100rpx;
  height: 100rpx;
  background: #f0fdf4;
  color: #16a34a;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  flex-shrink: 0;
}

.security-status-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #27272a;
  display: block;
  margin-bottom: 8rpx;
}

.security-status-desc {
  font-size: 28rpx;
  color: #71717a;
  font-weight: 700;
  display: block;
}

/* Settings Section */
.settings-section {
  margin-bottom: 48rpx;
}

.settings-section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #52525b;
  display: block;
  padding: 0 16rpx;
  margin-bottom: 24rpx;
}

.settings-card {
  background: #fff;
  border-radius: 48rpx;
  overflow: hidden;
  border: 1rpx solid #f1f1f1;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.security-action {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 48rpx;
  border-bottom: 1rpx solid #fafafa;
}

.security-action:last-child {
  border-bottom: none;
}

.security-action:active {
  background: #fafafa;
}

.security-action-left {
  display: flex;
  align-items: center;
  gap: 28rpx;
  flex: 1;
}

.security-action-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  background: #fafafa;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
}

.security-action-icon-svg {
  width: 40rpx;
  height: 40rpx;
  padding: 20rpx;
  background: #fafafa;
  border-radius: 24rpx;
  flex-shrink: 0;
}

.security-action-text {
  flex: 1;
}

.security-action-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #27272a;
  display: block;
  margin-bottom: 4rpx;
}

.security-action-desc {
  font-size: 24rpx;
  color: #a1a1aa;
  font-weight: 700;
  display: block;
}

.security-action-arrow {
  color: #d4d4d8;
  font-size: 28rpx;
}

/* Danger Section */
.danger-section {
  padding-top: 80rpx;
  text-align: center;
}

.danger-btn {
  width: 100%;
  height: 112rpx;
  color: var(--color-error);
  font-weight: 700;
  font-size: 32rpx;
  border: 3rpx solid #f1f1f1;
  border-radius: 48rpx;
  background: none;
  line-height: 112rpx;
}

.danger-btn:active {
  background: #fafafa;
}

.danger-warn {
  font-size: 24rpx;
  color: #a1a1aa;
  font-weight: 700;
  display: block;
  margin-top: 32rpx;
}
