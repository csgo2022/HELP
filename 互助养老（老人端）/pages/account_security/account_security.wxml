<view class="page-container">
  <view class="page-header">
    <view class="page-header-left">
      <button class="back-btn" bindtap="goBack">◀</button>
      <text class="page-title" style="color: #27272a;">账号与安全</text>
    </view>
    <view class="header-spacer"></view>
  </view>

  <view class="security-status-card">
    <view class="security-status-icon-wrap"><image class="icon-svg-lg" src="/images/icons/shield-check.svg" mode="aspectFit" style="stroke:#16a34a;stroke-width:2;" /></view>
    <view class="security-status-text">
      <text class="security-status-title">账号状态：安全</text>
      <text class="security-status-desc">您的账号目前非常安全</text>
    </view>
  </view>

  <view class="settings-section">
    <text class="settings-section-title">常用操作</text>
    <view class="settings-card">
      <view class="security-action" bindtap="goChangePassword">
        <view class="security-action-left">
          <view class="security-action-icon-wrap">🔒</view>
          <view class="security-action-text">
            <text class="security-action-title">修改登录密码</text>
            <text class="security-action-desc">建议定期更换，更安全</text>
          </view>
        </view>
        <text class="security-action-arrow">▶</text>
      </view>
      <view class="security-action" bindtap="goChangePhone">
        <view class="security-action-left">
          <view class="security-action-icon-wrap">📞</view>
          <view class="security-action-text">
            <text class="security-action-title">换绑手机号</text>
            <text class="security-action-desc">138****9527</text>
          </view>
        </view>
        <text class="security-action-arrow">▶</text>
      </view>
    </view>
  </view>

  <view class="danger-section">
    <button class="danger-btn" bindtap="onDeleteAccount">注销账号</button>
    <text class="danger-warn">注销后将无法找回您的任何数据，请谨慎操作</text>
  </view>
</view>
