.edit-profile-content {
  padding: 48rpx 40rpx 180rpx;
  max-width: 700rpx;
  margin: 0 auto;
}

/* Avatar Section */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 48rpx;
}

.avatar-wrap {
  position: relative;
  margin-bottom: 16rpx;
}

.avatar-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: var(--color-primary-container);
  color: white;
  font-size: 56rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx -4rpx rgba(155, 69, 0, 0.25);
}

.avatar-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  object-fit: cover;
  box-shadow: 0 8rpx 24rpx -4rpx rgba(155, 69, 0, 0.25);
}

.camera-overlay {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: var(--color-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid white;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.camera-icon {
  width: 28rpx;
  height: 28rpx;
}

.avatar-hint {
  font-size: 22rpx;
  color: var(--color-on-surface-variant);
  font-weight: 500;
}

/* Form Card */
.form-card {
  background: white;
  border-radius: 56rpx;
  padding: 40rpx;
  box-shadow: 0 12rpx 32rpx -8rpx rgba(148, 107, 82, 0.15);
  border: 2rpx solid rgba(255, 140, 66, 0.05);
  margin-bottom: 48rpx;
}

.form-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  min-height: 80rpx;
}

.form-label {
  font-size: 26rpx;
  color: var(--color-on-surface-variant);
  font-weight: 500;
  flex-shrink: 0;
  margin-right: 24rpx;
  width: 140rpx;
}

.form-input {
  flex: 1;
  font-size: 26rpx;
  color: var(--color-on-surface);
  font-weight: 700;
  text-align: right;
  padding: 8rpx 0;
  background: transparent;
  border: none;
  outline: none;
}

.form-input::placeholder {
  color: #cbc3be;
  font-weight: 500;
}

.divider {
  height: 2rpx;
  background: #f1ece8;
}

/* Gender Toggle */
.gender-group {
  display: flex;
  gap: 16rpx;
}

.gender-btn {
  padding: 12rpx 40rpx;
  border-radius: 100rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: var(--color-on-surface-variant);
  background: rgba(148, 107, 82, 0.06);
  transition: all 0.2s;
}

.gender-btn:active {
  transform: scale(0.95);
}

.gender-active {
  background: var(--color-primary);
  color: white;
}

/* Submit Button */
.submit-btn {
  width: 100%;
  background: var(--color-primary);
  color: white;
  font-size: 28rpx;
  font-weight: 800;
  padding: 32rpx 0;
  border-radius: 32rpx;
  border: none;
  text-align: center;
  box-shadow: 0 8rpx 24rpx -4rpx rgba(155, 69, 0, 0.3);
}

.submit-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}
