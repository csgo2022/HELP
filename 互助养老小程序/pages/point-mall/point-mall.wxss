.mall-content {
  padding: 32rpx 40rpx 180rpx;
  max-width: 700rpx;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  gap: 48rpx;
}

/* Points Balance Card */
.points-card {
  border-radius: 48rpx;
  padding: 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  border: 2rpx solid rgba(255, 140, 66, 0.15);
}

.points-label {
  font-size: 24rpx;
  color: var(--color-primary);
  font-weight: 700;
  opacity: 0.8;
}

.points-row {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.points-number {
  font-size: 88rpx;
  font-weight: 900;
  color: var(--color-primary);
  line-height: 1;
}

.points-unit {
  font-size: 32rpx;
  color: var(--color-primary);
  font-weight: 700;
}

.points-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 24rpx;
}

.points-btn {
  padding: 20rpx 48rpx;
  border-radius: 100rpx;
  font-size: 26rpx;
  font-weight: 700;
  transition: transform 0.15s;
}

.points-btn:active {
  transform: scale(0.97);
}

.points-btn-outline {
  background: white;
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary-container);
}

.points-btn-primary {
  background: var(--color-primary);
  color: white;
  box-shadow: 0 8rpx 16rpx -4rpx rgba(155, 69, 0, 0.3);
}

/* Category Filters */
.category-scroll {
  white-space: nowrap;
  overflow: hidden;
}

.category-row {
  display: flex;
  gap: 24rpx;
  padding: 4rpx 0;
}

.category-item {
  display: inline-block;
  padding: 20rpx 40rpx;
  border-radius: 100rpx;
  font-size: 26rpx;
  font-weight: 700;
  white-space: nowrap;
  transition: transform 0.15s;
}

.category-item:active {
  transform: scale(0.97);
}

.category-active {
  background: var(--color-primary);
  color: white;
  box-shadow: 0 8rpx 16rpx -4rpx rgba(155, 69, 0, 0.25);
}

.category-default {
  background: white;
  color: var(--color-on-surface-variant);
  border: 2rpx solid var(--color-outline-variant);
}

/* Section */
.section {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.section-head {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.section-icon {
  width: 40rpx;
  height: 40rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-on-surface);
}

/* Exchange Cards */
.exchange-list {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.exchange-card {
  border-radius: 40rpx;
  padding: 40rpx;
  border: 2rpx solid rgba(255, 140, 66, 0.15);
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.exchange-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.exchange-desc {
  font-size: 24rpx;
  color: var(--color-on-surface-variant);
  font-weight: 500;
  line-height: 1.5;
}

.exchange-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
}

.exchange-points {
  font-size: 40rpx;
  font-weight: 900;
  color: var(--color-primary);
}

.exchange-btn {
  background: var(--color-primary);
  color: white;
  padding: 20rpx 52rpx;
  border-radius: 100rpx;
  font-size: 26rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 16rpx -4rpx rgba(155, 69, 0, 0.25);
}

.exchange-btn:active {
  transform: scale(0.97);
}

/* Product Bento Grid */
.product-list {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.product-card {
  background: white;
  border-radius: 40rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 32rpx -8rpx rgba(148, 107, 82, 0.15);
  display: flex;
  flex-direction: column;
}

.product-card:active {
  transform: scale(0.98);
}

.product-img-wrap {
  height: 320rpx;
  position: relative;
  overflow: hidden;
}

.product-img {
  width: 100%;
  height: 100%;
  display: block;
}

.product-img-placeholder {
  height: 320rpx;
  background: linear-gradient(135deg, #f5ece8 0%, #efe6e2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-text {
  font-size: 28rpx;
  color: #8c7c73;
  font-weight: 700;
}

.product-badge {
  position: absolute;
  top: 24rpx;
  left: 24rpx;
  background: var(--color-primary-container);
  color: white;
  padding: 8rpx 24rpx;
  border-radius: 100rpx;
  font-size: 20rpx;
  font-weight: 700;
  box-shadow: 0 4rpx 12rpx rgba(155, 69, 0, 0.2);
}

.product-name {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-on-surface);
  padding: 32rpx 32rpx 0;
  line-height: 1.3;
}

.product-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx 32rpx;
}

.product-points {
  font-size: 38rpx;
  font-weight: 900;
  color: var(--color-primary);
}

.exchange-sm-btn {
  background: var(--color-primary-container);
  color: white;
  padding: 16rpx 40rpx;
  border-radius: 100rpx;
  font-size: 24rpx;
  font-weight: 700;
  box-shadow: 0 4rpx 12rpx rgba(155, 69, 0, 0.15);
}

.exchange-sm-btn:active {
  transform: scale(0.97);
}

/* Info Banner */
.info-banner {
  background: rgba(255, 140, 66, 0.06);
  border: 2rpx solid rgba(255, 140, 66, 0.12);
  border-radius: 40rpx;
  padding: 40rpx;
  display: flex;
  gap: 24rpx;
}

.info-icon {
  width: 40rpx;
  height: 40rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.info-text-wrap {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  flex: 1;
}

.info-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-on-surface);
}

.info-desc {
  font-size: 22rpx;
  color: var(--color-on-surface-variant);
  font-weight: 500;
  line-height: 1.6;
}
