.address-content {
  padding: 32rpx 40rpx 200rpx;
  max-width: 700rpx;
  margin: 0 auto;
}

.address-list {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

/* Card with left bar */
.address-card {
  background: white;
  border-radius: 36rpx;
  overflow: hidden;
  display: flex;
  box-shadow: 0 12rpx 32rpx -8rpx rgba(148, 107, 82, 0.15);
  transition: transform 0.2s;
}

.address-card:active {
  transform: scale(0.98);
}

.card-left-bar {
  width: 12rpx;
  background: linear-gradient(180deg, var(--color-primary-container, #c7511f), #e8915a);
  flex-shrink: 0;
}

.card-body {
  flex: 1;
  padding: 40rpx 36rpx 32rpx;
}

.card-top {
  margin-bottom: 24rpx;
}

.card-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.card-name {
  font-size: 34rpx;
  font-weight: 800;
  color: #1a1a1a;
}

.card-contact-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.card-phone {
  font-size: 24rpx;
  font-weight: 600;
  color: #52525b;
}

.card-address {
  display: block;
  font-size: 24rpx;
  color: #8c7c73;
  line-height: 1.5;
  padding-right: 16rpx;
  font-weight: 500;
}

.card-selectable {
  cursor: pointer;
  border: 2rpx solid transparent;
  transition: border-color 0.2s;
}

.card-selectable:active {
  border-color: var(--color-primary-container, #c7511f);
  box-shadow: 0 8rpx 24rpx rgba(199, 81, 31, 0.15);
}

.address-badge {
  font-size: 16rpx;
  font-weight: 900;
  background: rgba(199, 81, 31, 0.1);
  color: var(--color-primary-container, #c7511f);
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
}

/* Card Actions */
.card-actions {
  padding-top: 20rpx;
  border-top: 2rpx solid #f1ece8;
}

.action-btn {
  height: 72rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  line-height: 72rpx;
  border: none;
  background: none;
  padding: 0;
}

.action-btn:active {
  transform: scale(0.95);
}

.action-icon {
  width: 32rpx;
  height: 32rpx;
}

.delete-btn {
  width: 100%;
  background: #fef2f2;
  color: #ef4444;
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon-wrap {
  width: 160rpx;
  height: 160rpx;
  background: #f5f0ec;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.empty-icon {
  width: 72rpx;
  height: 72rpx;
  opacity: 0.35;
}

.empty-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #52525b;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: #a1a1aa;
  font-weight: 500;
}

/* Bottom Bar */
.bottom-bar-gradient {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 48rpx;
  background: linear-gradient(to top, var(--color-surface, #f6f0e8), transparent);
  z-index: 40;
}

.add-address-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  width: 100%;
  height: 112rpx;
  background: var(--color-primary-container, #c7511f);
  color: white;
  font-size: 28rpx;
  font-weight: 700;
  border-radius: 36rpx;
  box-shadow: 0 12rpx 32rpx rgba(155, 69, 0, 0.2);
}

.add-address-btn:active { transform: scale(0.97); }

.add-loc-icon { width: 40rpx; height: 40rpx; }
