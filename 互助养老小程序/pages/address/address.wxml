<top-app-bar title="我的地址" showBack="{{true}}"></top-app-bar>

<view class="address-content">
  <view class="address-list" wx:if="{{addresses.length > 0}}">
    <view class="address-card {{selectMode ? 'card-selectable' : ''}}" wx:for="{{addresses}}" wx:key="id" data-id="{{item.id}}" data-name="{{item.name}}" data-phone="{{item.phone}}" data-address="{{item.address}}" bindtap="{{selectMode ? 'onSelectAddress' : ''}}">
      <view class="card-left-bar"></view>
      <view class="card-body">
        <view class="card-top">
          <view class="card-title-row">
            <text class="card-name">{{item.name || '地址'}}</text>
            <view class="address-badge" wx:if="{{item.default}}">默认</view>
          </view>
          <view class="card-contact-row">
            <text class="card-phone">{{item.phone}}</text>
          </view>
          <text class="card-address">{{item.address}}</text>
        </view>
        <view class="card-actions" wx:if="{{!selectMode}}">
          <button class="action-btn delete-btn" bindtap="onDeleteAddress" data-id="{{item.id}}" data-name="{{item.name}}" catchtap>
            <image class="action-icon" src="/images/icons/close.svg" mode="aspectFit" /> 删除
          </button>
        </view>
      </view>
    </view>
  </view>

  <!-- Empty state -->
  <view class="empty-state" wx:else>
    <view class="empty-icon-wrap">
      <image class="empty-icon" src="/images/icons/location.svg" mode="aspectFit" />
    </view>
    <text class="empty-title">暂无地址</text>
    <text class="empty-desc">点击下方按钮添加您的常用地址</text>
  </view>
</view>

<view class="bottom-bar-gradient">
  <navigator url="/pages/add-address/add-address" class="add-address-btn">
    <image class="add-loc-icon" src="/images/icons/add.svg" mode="aspectFit" />
    <text>添加新地址</text>
  </navigator>
</view>
