<top-app-bar title="互助养老"></top-app-bar>

<view class="booking-content">
  <!-- Search Bar -->
  <view class="search-bar">
    <image class="search-icon" src="/images/icons/search.svg" mode="aspectFit" />
    <input class="search-input" type="text" placeholder="搜索服务需求..." bindinput="onSearchInput" value="{{searchKeyword}}" />
    <view class="search-clear" wx:if="{{searchKeyword}}" bindtap="onSearchClear">
      <image class="clear-icon" src="/images/icons/close.svg" mode="aspectFit" />
    </view>
  </view>

  <!-- Filters -->
  <scroll-view class="filter-scroll" scroll-x="{{true}}" show-scrollbar="{{false}}">
    <view class="filter-list">
      <view class="filter-item {{activeFilter === 0 ? 'filter-active' : 'filter-default'}}" data-index="0" bindtap="onFilterTap">全部</view>
      <view class="filter-item {{activeFilter === (index+1) ? 'filter-active' : 'filter-default'}}" wx:for="{{categories}}" wx:key="this" data-index="{{index+1}}" bindtap="onFilterTap">{{item}}</view>
    </view>
  </scroll-view>

  <!-- Task List -->
  <view class="task-list">
    <view class="task-card" wx:for="{{filteredTasks}}" wx:key="id">
      <view class="task-top">
        <view class="task-user">
          <view class="task-icon-wrap bg-orange-light">
            <image class="task-icon" src="/images/icons/{{item.icon}}.svg" mode="aspectFit" />
          </view>
          <view class="task-info">
            <text class="task-title">{{item.title}}</text>
          </view>
        </view>
        <view class="task-reward">
          <image class="clock-icon" src="/images/icons/schedule.svg" mode="aspectFit" />
          <text class="reward-text">{{item.reward}}</text>
        </view>
      </view>

      <view class="task-details">
        <view class="task-time">
          <image class="detail-icon" src="/images/icons/schedule.svg" mode="aspectFit" />
          <text class="detail-text">{{item.time}}</text>
        </view>
        <view class="task-time" wx:if="{{item.address}}">
          <image class="detail-icon" src="/images/icons/location.svg" mode="aspectFit" />
          <text class="detail-text">{{item.address}}</text>
        </view>
        <text class="task-desc">{{item.description}}</text>
      </view>

      <view class="task-action">
        <navigator url="/pages/service-detail/service-detail?id={{item.id}}">
          <view class="signup-btn">
            <text>一键报名</text>
            <image class="send-icon" src="/images/icons/send.svg" mode="aspectFit" />
          </view>
        </navigator>
      </view>
    </view>
  </view>

  <!-- Empty State -->
  <view class="empty-state" wx:if="{{filteredTasks.length === 0}}">
    <image class="empty-icon" src="/images/icons/search.svg" mode="aspectFit" />
    <text class="empty-title">暂无匹配的服务</text>
    <text class="empty-desc">试试调整搜索条件或筛选分类</text>
  </view>
</view>
