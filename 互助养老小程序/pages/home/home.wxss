/* =============================================
   首页样式 — "纸间温度" 设计语言
   ============================================= */

.page-content {
  padding: 0 32rpx 48rpx;
  max-width: 700rpx;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  gap: 40rpx;
}

/* =============================================
   Hero Section — 温暖问候
   ============================================= */
.hero-section {
  position: relative;
  background: linear-gradient(145deg, #c7511f 0%, #a83e12 100%);
  border-radius: 48rpx;
  padding: 40rpx 40rpx 36rpx;
  overflow: hidden;
  margin-top: 16rpx;
  box-shadow: 0 16rpx 48rpx -12rpx rgba(167, 62, 18, 0.35);
}

.hero-bg-shape {
  position: absolute;
  top: -60rpx;
  right: -40rpx;
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
  pointer-events: none;
}

.hero-bg-shape::after {
  content: '';
  position: absolute;
  bottom: -80rpx;
  left: -60rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.04);
}

.hero-content {
  position: relative;
  z-index: 1;
}

.hero-greeting {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 6rpx;
}

.hero-name {
  display: block;
  font-size: 52rpx;
  font-weight: 900;
  color: #ffffff;
  letter-spacing: 2rpx;
  margin-bottom: 28rpx;
  line-height: 1.2;
}

.hero-stats-row {
  display: flex;
  align-items: center;
  gap: 0;
  background: rgba(255, 255, 255, 0.12);
  backdrop-filter: blur(10px);
  border-radius: 28rpx;
  padding: 20rpx 0;
}

.hero-stat {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.hero-stat-value {
  font-size: 32rpx;
  font-weight: 800;
  color: #ffffff;
  line-height: 1.2;
}

.hero-stat-label {
  font-size: 20rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.75);
}

.hero-stat-divider {
  width: 2rpx;
  height: 40rpx;
  background: rgba(255, 255, 255, 0.15);
}

/* =============================================
   Section Layout
   ============================================= */
.section {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 8rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #2c1810;
  letter-spacing: 0.5rpx;
}

.section-badge {
  background: #fee8dc;
  padding: 8rpx 24rpx;
  border-radius: 100rpx;
}

.section-badge-text {
  font-size: 22rpx;
  font-weight: 700;
  color: #c7511f;
}

/* =============================================
   Task Cards — 便签纸风格
   ============================================= */
.task-card {
  display: block;
  background: #ffffff;
  border-radius: 40rpx;
  position: relative;
  box-shadow:
    0 4rpx 16rpx rgba(100, 60, 30, 0.06),
    0 12rpx 32rpx -8rpx rgba(100, 60, 30, 0.08);
  border: 2rpx solid rgba(199, 81, 31, 0.06);
  overflow: hidden;
}

.task-card-hover {
  opacity: 0.96;
  transform: translateY(-4rpx);
}

/* 左上角图钉装饰 */
.task-card-pin {
  position: absolute;
  top: 20rpx;
  left: 50%;
  margin-left: -12rpx;
  width: 24rpx;
  height: 24rpx;
  background: radial-gradient(circle at 35% 35%, #b0a090, #8a7a6e);
  border-radius: 50%;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.15);
  z-index: 1;
}

.task-card-pin::after {
  content: '';
  position: absolute;
  top: 4rpx;
  left: 8rpx;
  width: 8rpx;
  height: 8rpx;
  background: rgba(255,255,255,0.4);
  border-radius: 50%;
}

.task-card-body {
  padding: 36rpx 36rpx 28rpx;
}

.task-card-top {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 20rpx;
}

.task-card-icon {
  width: 80rpx;
  height: 80rpx;
  background: rgba(199, 81, 31, 0.08);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.task-card-icon-img {
  width: 40rpx;
  height: 40rpx;
}

.task-card-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.task-card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2c1810;
  line-height: 1.3;
}

.task-card-desc {
  font-size: 24rpx;
  font-weight: 500;
  color: #8a7a6e;
}

.task-card-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 20rpx;
  border-top: 2rpx solid #f0ebe4;
}

.task-card-time {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.task-card-time-icon {
  width: 28rpx;
  height: 28rpx;
  opacity: 0.5;
}

.task-card-time-text {
  font-size: 22rpx;
  color: #8a7a6e;
  font-weight: 500;
}

.task-card-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: #c7511f;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
  padding: 16rpx 28rpx;
  border-radius: 100rpx;
  box-shadow: 0 4rpx 12rpx rgba(199, 81, 31, 0.25);
}

.task-card-btn:active {
  transform: scale(0.95);
}

.task-card-btn-icon {
  width: 20rpx;
  height: 20rpx;
}

/* Empty State */
.empty-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #ffffff;
  border-radius: 40rpx;
  padding: 48rpx 40rpx;
  box-shadow:
    0 4rpx 16rpx rgba(100, 60, 30, 0.04),
    0 8rpx 24rpx -8rpx rgba(100, 60, 30, 0.06);
}

.empty-card-dot {
  width: 16rpx;
  height: 16rpx;
  background: #d4a043;
  border-radius: 50%;
  flex-shrink: 0;
}

.empty-card-text {
  font-size: 26rpx;
  color: #8a7a6e;
  font-weight: 500;
}

/* =============================================
   Notice Swiper — 公告板 + 胶带装饰
   ============================================= */
.notice-swiper {
  height: 340rpx;
  border-radius: 40rpx;
  overflow: hidden;
  box-shadow:
    0 4rpx 16rpx rgba(100, 60, 30, 0.06),
    0 12rpx 32rpx -8rpx rgba(100, 60, 30, 0.08);
}

.notice-slide {
  position: relative;
  width: 100%;
  height: 100%;
}

/* 胶带装饰 */
.notice-slide-tape {
  position: absolute;
  top: -4rpx;
  left: 50%;
  margin-left: -40rpx;
  width: 80rpx;
  height: 24rpx;
  background: rgba(212, 160, 67, 0.5);
  border-radius: 4rpx;
  transform: rotate(-2deg);
  z-index: 2;
}

.notice-slide-img {
  width: 100%;
  height: 100%;
}

.notice-slide-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(to top, rgba(44, 24, 16, 0.7) 0%, transparent 100%);
  padding: 60rpx 40rpx 36rpx;
}

.notice-slide-title {
  display: block;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.3;
  margin-bottom: 8rpx;
}

.notice-slide-desc {
  display: block;
  color: rgba(255, 255, 255, 0.8);
  font-size: 24rpx;
  font-weight: 500;
}

/* =============================================
   Bento Grid — 多彩快捷入口
   ============================================= */
.bento-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
}

.bento-card {
  position: relative;
  border-radius: 40rpx;
  overflow: hidden;
  min-height: 280rpx;
  display: flex;
  box-shadow:
    0 4rpx 16rpx rgba(100, 60, 30, 0.06),
    0 8rpx 24rpx -8rpx rgba(100, 60, 30, 0.06);
}

.bento-hover {
  transform: translateY(-6rpx);
}

.bento-card-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  opacity: 0.15;
}

.bento-card-content {
  position: relative;
  z-index: 1;
  padding: 36rpx;
  display: flex;
  flex-direction: column;
  flex: 1;
}

.bento-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(4rpx);
}

.bento-icon {
  width: 40rpx;
  height: 40rpx;
}

.bento-title {
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.2;
  margin-bottom: 6rpx;
}

.bento-desc {
  font-size: 22rpx;
  font-weight: 500;
  opacity: 0.8;
}

/* 各卡片配色 */
.bento-card-ai {
  background: linear-gradient(145deg, #7c5cbf 0%, #6341a8 100%);
  color: #ffffff;
}

.bento-card-announce {
  background: linear-gradient(145deg, #3a7d4c 0%, #2d6a3e 100%);
  color: #ffffff;
}
