.rdetail-content {
  padding: 32rpx 40rpx 80rpx;
  max-width: 700rpx;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  gap: 48rpx;
}

.success-card {
  background: white;
  border-radius: 48rpx;
  padding: 64rpx;
  text-align: center;
  box-shadow: 0 12rpx 32rpx -8rpx rgba(148, 107, 82, 0.15);
  position: relative;
  overflow: hidden;
}

.success-inner {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.success-icon-wrap {
  width: 144rpx;
  height: 144rpx;
  background: rgba(38, 109, 0, 0.05);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.success-icon { width: 80rpx; height: 80rpx; }

.success-title { font-size: 36rpx; font-weight: 900; }
.success-date { font-size: 22rpx; color: #8c7c73; font-weight: 700; margin-bottom: 24rpx; }

.success-stats {
  display: flex;
  align-items: center;
  gap: 48rpx;
  margin-top: 24rpx;
}

.success-stat { text-align: center; }
.ss-label { display: block; font-size: 16rpx; color: #8c7c73; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8rpx; }
.ss-value { font-size: 44rpx; font-weight: 900; color: var(--color-primary-container); }
.ss-unit { font-size: 22rpx; font-weight: 500; margin-left: 8rpx; }
.text-green { color: var(--color-secondary); }
.ss-divider { width: 2rpx; height: 80rpx; background: #f1ece8; }

/* Info Section */
.info-section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 24rpx;
  padding: 0 16rpx;
}

.info-card {
  background: white;
  border-radius: 48rpx;
  padding: 24rpx 48rpx;
  box-shadow: 0 12rpx 32rpx -8rpx rgba(148, 107, 82, 0.15);
}

.info-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
  border-bottom: 2rpx solid #faf8f6;
}

.info-item:last-child { border-bottom: none; }

.info-left { display: flex; align-items: center; gap: 16rpx; }
.info-icon { width: 28rpx; height: 28rpx; }
.info-label { font-size: 22rpx; color: #8c7c73; font-weight: 700; }
.info-value { font-size: 22rpx; font-weight: 700; }

/* Summary */
.summary-card {
  background: white;
  border-radius: 48rpx;
  padding: 48rpx;
  box-shadow: 0 12rpx 32rpx -8rpx rgba(148, 107, 82, 0.15);
}

.summary-text {
  font-size: 24rpx;
  color: var(--color-on-surface-variant);
  line-height: 1.6;
  font-weight: 500;
}

/* Certificate */
.cert-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  height: 112rpx;
  background: var(--color-surface-high);
  color: var(--color-primary-container);
  font-weight: 700;
  font-size: 28rpx;
  border-radius: 36rpx;
  border: 2rpx solid rgba(255, 140, 66, 0.08);
}

.cert-btn:active { transform: scale(0.97); }

.cert-icon { width: 32rpx; height: 32rpx; }
