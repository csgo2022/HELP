.announcement-content {
  padding: 32rpx 40rpx 80rpx;
  max-width: 700rpx;
  margin: 0 auto;
}

.search-bar {
  position: relative;
  display: flex;
  align-items: center;
  margin-bottom: 48rpx;
}

.search-icon {
  position: absolute;
  left: 32rpx;
  width: 32rpx;
  height: 32rpx;
  z-index: 1;
}

.search-input {
  width: 100%;
  height: 112rpx;
  background: white;
  border-radius: 28rpx;
  padding-left: 88rpx;
  font-size: 28rpx;
  font-weight: 700;
  box-sizing: border-box;
  box-shadow: 0 12rpx 32rpx -8rpx rgba(148, 107, 82, 0.15);
  border: 2rpx solid transparent;
}

.announce-list {
  display: flex;
  flex-direction: column;
  gap: 48rpx;
}

.announce-card {
  display: block;
  background: white;
  border-radius: 48rpx;
  padding: 48rpx;
  box-shadow: 0 12rpx 32rpx -8rpx rgba(148, 107, 82, 0.15);
}

.announce-hover { transform: scale(0.98); }

.announce-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 32rpx;
}

.announce-icon-bg {
  width: 88rpx;
  height: 88rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.bg-orange-light { background: rgba(255, 140, 66, 0.1); }
.bg-default { background: rgba(66, 133, 244, 0.06); }
.announce-icon { width: 40rpx; height: 40rpx; }

.announce-badges { display: flex; gap: 12rpx; }

.badge-top, .badge-new {
  font-size: 16rpx;
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: 1px;
  padding: 4rpx 16rpx;
  border-radius: 100rpx;
  color: white;
}

.badge-top { background: var(--color-primary); }
.badge-new { background: var(--color-secondary); }

.announce-meta-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.announce-category {
  font-size: 20rpx;
  font-weight: 900;
  color: var(--color-primary-container);
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

.announce-date { font-size: 20rpx; color: #8c7c73; font-weight: 700; }

.announce-title {
  display: block;
  font-size: 30rpx;
  font-weight: 900;
  color: var(--color-on-surface);
  line-height: 1.3;
  margin-bottom: 16rpx;
}

.announce-desc {
  display: block;
  font-size: 22rpx;
  color: var(--color-on-surface-variant);
  line-height: 1.5;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.announce-footer {
  margin-top: 32rpx;
  padding-top: 32rpx;
  border-top: 2rpx solid #faf8f6;
  display: flex;
  justify-content: flex-end;
}

.announce-more {
  font-size: 22rpx;
  font-weight: 900;
  color: var(--color-primary-container);
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.tip-card {
  background: rgba(255, 140, 66, 0.05);
  padding: 40rpx;
  border-radius: 36rpx;
  border: 2rpx solid rgba(255, 140, 66, 0.1);
  display: flex;
  gap: 24rpx;
  margin-top: 64rpx;
}

.tip-icon { width: 32rpx; height: 32rpx; flex-shrink: 0; }

.tip-text {
  font-size: 20rpx;
  color: var(--color-on-surface-variant);
  line-height: 1.5;
  font-weight: 700;
}
