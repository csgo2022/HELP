.detail-content {
  padding: 32rpx 40rpx 200rpx;
  max-width: 700rpx;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

/* Hero Card */
.hero-card {
  background: linear-gradient(135deg, #ff8c42 0%, #ff6b35 100%);
  border-radius: 48rpx;
  padding: 48rpx;
  color: #fff;
}

.hero-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.hero-title {
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1.3;
  flex: 1;
}

.hero-badge {
  flex-shrink: 0;
  padding: 8rpx 24rpx;
  border-radius: 100rpx;
  font-size: 22rpx;
  font-weight: 700;
  background: rgba(255,255,255,0.25);
}

.hero-badge.pending { background: rgba(255,255,255,0.3); }
.hero-badge.matching { background: rgba(255,255,255,0.3); }
.hero-badge.in_progress { background: rgba(46, 204, 113, 0.4); }
.hero-badge.completed { background: rgba(52, 152, 219, 0.4); }
.hero-badge.cancelled { background: rgba(149, 165, 166, 0.5); }

.hero-reward {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 24rpx;
  font-size: 28rpx;
  font-weight: 600;
  opacity: 0.9;
}

.hero-star { width: 32rpx; height: 32rpx; }

/* Info Card */
.info-card {
  background: #fff;
  border-radius: 48rpx;
  padding: 32rpx 40rpx;
  box-shadow: 0 8rpx 24rpx -8rpx rgba(0,0,0,0.06);
}

.info-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 24rpx 0;
  gap: 32rpx;
}

.info-label {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
  font-size: 26rpx;
  font-weight: 600;
  color: #8c8c8c;
}

.info-icon { width: 32rpx; height: 32rpx; opacity: 0.5; }

.info-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  text-align: right;
  flex: 1;
  word-break: break-all;
}

.info-value-right {
  text-align: right;
  flex: 1;
}

.info-sub {
  display: block;
  font-size: 22rpx;
  color: #ff8c42;
  font-weight: 600;
  margin-top: 4rpx;
}

.info-addr {
  max-width: 400rpx;
}

.info-divider {
  height: 2rpx;
  background: #f0f0f0;
}

/* Description Card */
.desc-card {
  background: #fff;
  border-radius: 48rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 24rpx -8rpx rgba(0,0,0,0.06);
}

.desc-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 20rpx;
}

.desc-head-icon { width: 32rpx; height: 32rpx; opacity: 0.5; }

.desc-body {
  display: block;
  font-size: 28rpx;
  line-height: 1.7;
  color: #52525b;
  font-weight: 500;
}

/* Applicant Bar */
.applicant-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 28rpx;
  background: #fff8f0;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #8c8c8c;
  font-weight: 500;
}

.applicant-icon { width: 32rpx; height: 32rpx; opacity: 0.4; }

.applicant-num {
  color: #ff8c42;
  font-weight: 800;
  font-size: 30rpx;
}

/* Bottom Bar */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(255,255,255,0.95);
  backdrop-filter: blur(20px);
  border-top: 2rpx solid rgba(0,0,0,0.04);
  padding: 32rpx 40rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  z-index: 50;
}

.bottom-bar-inner {
  max-width: 700rpx;
  margin: 0 auto;
}

.signup-big-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  width: 100%;
  height: 112rpx;
  background: linear-gradient(135deg, #ff8c42 0%, #ff6b35 100%);
  color: white;
  font-size: 34rpx;
  font-weight: 700;
  border-radius: 36rpx;
  box-shadow: 0 12rpx 32rpx rgba(255, 107, 53, 0.25);
  letter-spacing: 2rpx;
}

.signup-big-btn:active { transform: scale(0.97); }

.handshake-icon { width: 36rpx; height: 36rpx; }

.bottom-bar-info {
  justify-content: center;
}

.pending-confirm-text {
  font-size: 28rpx;
  color: #ff8c42;
  font-weight: 600;
  text-align: center;
  display: block;
  padding: 20rpx 0;
}

/* Review Card */
.review-card {
  background: #fff;
  border-radius: 48rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 24rpx -8rpx rgba(0,0,0,0.06);
}

.review-card-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 20rpx;
}

.review-card-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  object-fit: cover;
  background: #f1f1f1;
}

.review-card-user {
  flex: 1;
}

.review-card-name {
  font-size: 30rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 6rpx;
}

.review-card-stars {
  display: flex;
  gap: 4rpx;
}

.review-star {
  font-size: 32rpx;
  color: #e4e4e7;
}

.review-star.active {
  color: #f59e0b;
}

.review-card-comment {
  display: block;
  font-size: 28rpx;
  line-height: 1.6;
  color: #52525b;
  padding-top: 20rpx;
  border-top: 2rpx solid #f1f1f1;
}

/* Guidance Button */
.bottom-bar-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.guidance-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 0 24rpx;
  height: 88rpx;
  background: #FFF8F0;
  border: 2rpx solid #F5E6D3;
  border-radius: 24rpx;
  flex-shrink: 0;
}

.guidance-btn:active {
  transform: scale(0.97);
}

.guidance-btn-icon {
  width: 32rpx;
  height: 32rpx;
}

.guidance-btn-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #E8751A;
  white-space: nowrap;
}