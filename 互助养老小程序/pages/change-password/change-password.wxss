.page {
  padding: 0 36rpx 80rpx;
  min-height: 100vh;
  background: #f6f0e8;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.page-band {
  height: 6rpx;
  width: 160rpx;
  background: linear-gradient(90deg, #c7511f, #e8915a);
  border-radius: 0 0 6rpx 6rpx;
  margin: 0 auto;
}

.header-area {
  padding: 8rpx 8rpx 0;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 900;
  color: #2c1810;
}

.header-desc {
  font-size: 24rpx;
  font-weight: 500;
  color: #8a7a6e;
}

.form-card {
  background: #ffffff;
  border-radius: 36rpx;
  padding: 40rpx 36rpx;
  display: flex;
  flex-direction: column;
  gap: 36rpx;
  box-shadow: 0 8rpx 24rpx -8rpx rgba(148, 107, 82, 0.1);
}

.form-group {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.form-label {
  font-size: 26rpx;
  font-weight: 700;
  color: #52525b;
}

.input-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: #faf8f6;
  border: 2rpx solid #f0ebe4;
  border-radius: 24rpx;
  padding: 0 28rpx;
  height: 100rpx;
  transition: border-color 0.2s;
}

.input-row:focus-within {
  border-color: #c7511f;
}

.input-icon {
  width: 36rpx;
  height: 36rpx;
  opacity: 0.35;
  flex-shrink: 0;
}

.form-input {
  flex: 1;
  height: 100rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #2c1810;
  background: none;
  border: none;
}

.form-input::placeholder {
  color: #c4b8ae;
  font-weight: 400;
}

.tip {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 0 8rpx;
}

.tip-icon {
  width: 28rpx;
  height: 28rpx;
  opacity: 0.3;
  flex-shrink: 0;
}

.tip-text {
  font-size: 22rpx;
  font-weight: 500;
  color: #a1a1aa;
  line-height: 1.4;
}

.submit-btn {
  width: 100%;
  height: 112rpx;
  background: linear-gradient(135deg, #c7511f, #a83e12);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  border-radius: 36rpx;
  border: none;
  box-shadow: 0 12rpx 32rpx rgba(199, 81, 31, 0.25);
  line-height: 112rpx;
  margin-top: 8rpx;
}

.submit-btn:active {
  transform: scale(0.97);
}

.submit-btn[disabled] {
  opacity: 0.5;
  box-shadow: none;
}
