<top-app-bar title="修改密码" showBack="{{true}}"></top-app-bar>

<view class="page">
  <view class="page-band"></view>

  <view class="header-area">
    <text class="header-title">账号与安全</text>
    <text class="header-desc">请先验证旧密码，再设置新密码</text>
  </view>

  <view class="form-card">
    <view class="form-group">
      <text class="form-label">旧密码</text>
      <view class="input-row">
        <image class="input-icon" src="/images/icons/lock.svg" mode="aspectFit" />
        <input class="form-input" type="password" placeholder="请输入当前密码" value="{{oldPassword}}" bindinput="onOldInput" />
      </view>
    </view>

    <view class="form-group">
      <text class="form-label">新密码</text>
      <view class="input-row">
        <image class="input-icon" src="/images/icons/lock.svg" mode="aspectFit" />
        <input class="form-input" type="password" placeholder="请输入新密码（至少6位）" value="{{newPassword}}" bindinput="onNewInput" />
      </view>
    </view>

    <view class="form-group">
      <text class="form-label">确认新密码</text>
      <view class="input-row">
        <image class="input-icon" src="/images/icons/lock.svg" mode="aspectFit" />
        <input class="form-input" type="password" placeholder="请再次输入新密码" value="{{confirmPassword}}" bindinput="onConfirmInput" />
      </view>
    </view>
  </view>

  <view class="tip">
    <image class="tip-icon" src="/images/icons/info.svg" mode="aspectFit" />
    <text class="tip-text">密码长度至少 6 位，建议包含数字和字母的组合</text>
  </view>

  <button class="submit-btn" bindtap="onSubmit" disabled="{{!canSubmit}}">
    <text wx:if="{{loading}}">提交中...</text>
    <text wx:else>确认修改</text>
  </button>
</view>
