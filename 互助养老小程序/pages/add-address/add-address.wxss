.add-address-content {
  padding: 32rpx 48rpx;
  min-height: 100vh;
  padding-bottom: 240rpx;
}

/* Map Picker */
.map-picker {
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: #fff;
  border-radius: 36rpx;
  padding: 32rpx 36rpx;
  box-shadow: 0 12rpx 32rpx -8rpx rgba(148, 107, 82, 0.12);
  margin-bottom: 48rpx;
  border: 2rpx solid #f1ece8;
}

.map-picker:active {
  transform: scale(0.98);
}

.map-picker-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #fef0e8 0%, #fce4d6 100%);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.map-picker-icon {
  width: 40rpx;
  height: 40rpx;
}

.map-picker-text-wrap {
  flex: 1;
}

.map-picker-label {
  font-size: 24rpx;
  font-weight: 700;
  color: #a1a1aa;
  display: block;
  margin-bottom: 4rpx;
}

.map-picker-value {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  display: block;
  line-height: 1.4;
}

.map-picker-value.placeholder {
  color: #c4c4c4;
  font-weight: 400;
}

.map-picker-arrow {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
  opacity: 0.3;
}

/* Form Area */
.form-area {
  display: flex;
  flex-direction: column;
  gap: 40rpx;
}

.input-group {
}

.input-label {
  font-size: 28rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 16rpx;
  color: #52525b;
}

.input-wrap {
  background: #fff;
  border-radius: 28rpx;
  box-shadow: 0 8rpx 24rpx -8rpx rgba(148, 107, 82, 0.08);
  border: 3rpx solid #f1ece8;
  transition: border-color 0.2s;
}

.input-wrap:focus-within {
  border-color: var(--color-primary-container, #c7511f);
}

.input-field {
  width: 100%;
  height: 100rpx;
  padding: 0 36rpx;
  font-size: 30rpx;
  font-weight: 500;
  background: none;
  border: none;
  box-sizing: border-box;
}

/* Bottom Bar */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(246, 240, 232, 0.95);
  backdrop-filter: blur(20px);
  border-top: 2rpx solid rgba(0,0,0,0.04);
  padding: 32rpx 48rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  z-index: 50;
}

.save-btn {
  width: 100%;
  height: 112rpx;
  background: linear-gradient(135deg, var(--color-primary-container, #c7511f) 0%, #e07840 100%);
  color: #fff;
  border-radius: 36rpx;
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  border: none;
  box-shadow: 0 12rpx 32rpx rgba(199, 81, 31, 0.25);
  line-height: 112rpx;
}

.save-btn:active {
  transform: scale(0.96);
}
