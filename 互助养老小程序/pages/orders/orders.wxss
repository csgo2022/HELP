.orders-content {
  padding: 32rpx 40rpx 180rpx;
  max-width: 700rpx;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.order-card {
  background: white;
  border-radius: 36rpx;
  box-shadow: 0 12rpx 32rpx -8rpx rgba(148, 107, 82, 0.15);
  overflow: hidden;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 40rpx;
  border-bottom: 2rpx solid #f1ece8;
}

.order-no {
  font-size: 22rpx;
  color: #a1a1aa;
  font-weight: 500;
}

.order-status {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--color-primary-container, #c7511f);
}

.product-row {
  display: flex;
  padding: 40rpx;
  gap: 32rpx;
}

.product-img-wrap {
  width: 160rpx;
  height: 160rpx;
  border-radius: 24rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.product-img {
  width: 100%;
  height: 100%;
  display: block;
}

.product-img-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: 24rpx;
  background: #f0e8e4;
  display: flex;
  align-items: center;
  justify-content: center;
}

.product-img-text {
  font-size: 48rpx;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  justify-content: center;
}

.product-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-on-surface);
}

.product-quantity {
  font-size: 24rpx;
  color: var(--color-on-surface-variant);
  font-weight: 500;
}

.product-points {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.logistics-section {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 28rpx 40rpx;
  border-top: 2rpx dashed #ece4df;
  margin: 0 40rpx;
}

.logistics-section:active {
  opacity: 0.8;
}

.logistics-icon {
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
}

.logistics-text {
  flex: 1;
  font-size: 22rpx;
  color: var(--color-on-surface-variant);
  font-weight: 500;
  line-height: 1.5;
}

.logistics-arrow {
  width: 24rpx;
  height: 24rpx;
  flex-shrink: 0;
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
  gap: 16rpx;
}

.empty-icon {
  width: 80rpx;
  height: 80rpx;
  opacity: 0.25;
  margin-bottom: 16rpx;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-on-surface-variant);
}

.empty-desc {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--color-outline);
}
