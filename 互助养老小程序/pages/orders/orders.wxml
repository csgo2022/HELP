<top-app-bar title="我的订单" showBack="{{true}}"></top-app-bar>

<view class="orders-content">
  <view class="order-card" wx:for="{{orders}}" wx:key="id">
    <!-- Header -->
    <view class="order-header">
      <text class="order-no">订单号：{{item.orderNo}}</text>
      <text class="order-status">{{item.statusText}}</text>
    </view>

    <!-- Product Row -->
    <view class="product-row">
      <view class="product-img-wrap">
        <image wx:if="{{item.productImage}}" src="{{item.productImage}}" mode="aspectFill" class="product-img" />
        <view class="product-img-placeholder" wx:else>
          <text class="product-img-text">📦</text>
        </view>
      </view>
      <view class="product-info">
        <text class="product-title">{{item.productName}}</text>
        <text class="product-quantity">× {{item.quantity}}</text>
        <text class="product-points">{{item.totalPoints}} 积分</text>
      </view>
    </view>

    <!-- Logistics Section -->
    <view class="logistics-section" wx:if="{{item.courier}}" bindtap="goToLogistics" data-id="{{item.id}}">
      <image class="logistics-icon" src="/images/icons/shipping.svg" mode="aspectFit" />
      <text class="logistics-text">{{item.courier}}：{{item.trackingNo}}</text>
      <image class="logistics-arrow" src="/images/icons/chevron-right.svg" mode="aspectFit" />
    </view>
  </view>

  <!-- Empty State -->
  <view class="empty-state" wx:if="{{orders.length === 0}}">
    <image class="empty-icon" src="/images/icons/redeem.svg" mode="aspectFit" />
    <text class="empty-title">暂无订单</text>
    <text class="empty-desc">去积分商城兑换心仪的商品吧</text>
  </view>
</view>
