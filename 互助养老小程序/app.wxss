/** app.wxss - 互助养老全局样式 **/

/* CSS 变量 - 主题色映射 */
page {
  --color-surface: #fff8f5;
  --color-surface-dim: #e1d8d4;
  --color-surface-bright: #fff8f5;
  --color-surface-lowest: #ffffff;
  --color-surface-low: #fbf2ed;
  --color-surface-container: #f5ece8;
  --color-surface-high: #efe6e2;
  --color-surface-highest: #eae1dc;
  --color-on-surface: #1f1b18;
  --color-on-surface-variant: #4a3c33;
  --color-primary: #9b4500;
  --color-on-primary: #ffffff;
  --color-primary-container: #ff8c42;
  --color-on-primary-container: #6a2d00;
  --color-secondary: #266d00;
  --color-on-secondary: #ffffff;
  --color-secondary-container: #85fa51;
  --color-on-secondary-container: #287100;
  --color-tertiary: #615e5b;
  --color-outline: #897266;
  --color-outline-variant: #ddc1b3;
  --color-error: #e14236;
  --font-sans: -apple-system, 'PingFang SC', 'Noto Sans SC', 'Microsoft YaHei', 'Helvetica Neue', sans-serif;

  background-color: var(--color-surface);
  color: var(--color-on-surface);
  font-family: var(--font-sans);
  font-size: 28rpx;
  font-weight: 400;
  line-height: 1.8;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  text-rendering: optimizeLegibility;
  -webkit-tap-highlight-color: transparent;
  box-sizing: border-box;
}

/* 公用卡片阴影 */
.card-shadow {
  box-shadow: 0 12rpx 32rpx -8rpx rgba(148, 107, 82, 0.15);
}

/* 强阴影 */
.redeem-shadow {
  box-shadow: 0 8rpx 16rpx -4rpx rgba(155, 69, 0, 0.4);
}

/* 时间银行渐变背景 */
.time-bank-gradient {
  background: linear-gradient(135deg, #FFF1E6 0%, #FFD8BE 100%);
}

/* 动画关键帧 */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(40rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes scaleIn {
  from { opacity: 0; transform: scale(0.9); }
  to { opacity: 1; transform: scale(1); }
}

@keyframes slideInRight {
  from { opacity: 0; transform: translateX(30rpx); }
  to { opacity: 1; transform: translateX(0); }
}

/* 按压反馈类 */
.btn-active:active {
  transform: scale(0.95);
}

/* 安全区底部 */
.safe-area-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

/* 隐藏滚动条 */
.scrollbar-hide::-webkit-scrollbar {
  display: none;
}
