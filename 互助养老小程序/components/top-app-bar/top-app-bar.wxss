.top-bar-wrapper {
  position: sticky;
  top: 0;
  z-index: 50;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20px);
}

.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  border-bottom: 2rpx solid #f1ece8;
  box-sizing: border-box;
}

.top-bar-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.top-bar-back {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.top-bar-back:active {
  background: rgba(0, 0, 0, 0.05);
}

.icon-back {
  width: 28rpx;
  height: 28rpx;
}

.avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 2rpx solid var(--color-primary-container);
  flex-shrink: 0;
}

.top-bar-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-on-primary-container);
  letter-spacing: -0.5rpx;
  white-space: nowrap;
}

.top-bar-right {
  position: relative;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.top-bar-right:active {
  background: rgba(255, 140, 66, 0.1);
}

.icon-notify, .icon-right {
  width: 32rpx;
  height: 32rpx;
}

.notify-badge {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  min-width: 24rpx;
  height: 24rpx;
  background: #e14236;
  color: white;
  font-size: 16rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
  font-weight: 700;
}
